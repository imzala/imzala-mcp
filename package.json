{
  "name": "@imzala/mcp-server",
  "version": "1.1.0",
  "description": "İmzala MCP server: sözleşme durumu, şablonlar, imzalı PDF indirme ve eser tescil (RFC3161 zaman damgası), API anahtarıyla",
  "type": "module",
  "bin": {
    "imzala-mcp": "dist/bin/stdio.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
